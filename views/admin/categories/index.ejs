<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ByteEats | Category Management</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
     <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

   <style>
    body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }
      /* Center the ByteEats logo */
.sidebar .logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 1.5rem;
}

.sidebar .logo a {
  font-size: 1.8rem; /* Adjust size if needed */
  font-weight: bold;
  color: #333; /* Adjust text color */
  text-decoration: none;
}

.sidebar .logo a:hover {
  color: #007bff; /* Change color on hover if desired */
}


    </style>
  </head>
  <body>
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('../partials/header') %> <% if (success_msg) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %> <% if (error_msg) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %>

      <!-- Header + Add Button -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Categories</h2>
        <a href="/admin/create/category" class="btn btn-success">
          <i class="bi bi-plus-square-fill"></i> Add Category
        </a>
      </div>

      <!-- Categories Table -->
      <div class="table-responsive">
        <table class="table table-bordered table-hover mt-3">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Category Name</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (categories && categories.length > 0) { %> <%
            categories.forEach(function(category, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= category.name %></td>
              <td>
                <a
                  href="/admin/view/category/<%= category.id %>"
                  class="btn btn-sm btn-info me-1"
                  title="View"
                >
                  <i class="bi bi-eye-fill"></i>
                </a>
                <a
                  href="/admin/edit/category/<%= category.id %>"
                  class="btn btn-sm btn-primary me-1"
                  title="Edit"
                >
                  <i class="bi bi-pencil-fill"></i>
                </a>
                <form
                  action="/admin/delete/category/<%= category.id %>?_method=DELETE"
                  method="POST"
                  style="display: inline"
                >
                 <a href="/admin/delete/category/<%= category.id %>" class="btn btn-danger">
  <i class="bi bi-trash"></i> 
</a>

                </form>
              </td>
            </tr>
            <% }); %> <% } else { %>
            <tr>
              <td colspan="4" class="text-center">No categories found.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
