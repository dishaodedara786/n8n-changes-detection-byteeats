<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Category Details | Admin Dashboard</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
    <style>
      body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }
      .category-info {
        background: #f8f9fa;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        margin: 0 auto;
        text-align: center;
      }
      .icon-box {
        width: 100px;
        height: 100px;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        color: #fff;
        background: #007bff;
        border-radius: 50%;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/header') %>

      <h2 class="text-center mb-4">Category Details</h2>

      <div class="category-info">
        <div class="icon-box">
          <i class="bi bi-tag-fill"></i>
        </div>
        <h4><%= category.name %></h4>
      

        <div class="d-flex justify-content-center gap-3 mt-3">
          <a
            href="/admin/edit/category/<%= category.id %>"
            class="btn btn-primary"
          >
            <i class="bi bi-pencil-fill"></i> Edit
          </a>
          <a href="/admin/categories" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back
          </a>
        </div>
      </div>
    </div>
  </body>
</html>
