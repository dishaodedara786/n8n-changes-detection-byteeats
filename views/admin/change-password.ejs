<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ByteEats | Admin Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
     <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <style>
      body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db; /* slightly darker than #dee2e6 */
        padding: 12px 20px;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('partials/header') %>

      <!-- Flash Messages -->
      <% if (success_msg) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %> <% if (error_msg) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %> <% if (success_msg) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %> <% if (error_msg) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error_msg %>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="alert"
          aria-label="Close"
        ></button>
      </div>
      <% } %>

      <form action="/change-password" method="POST" class="main-form">
        <h4 class="form-title">Change Password</h4>

        <input
          type="password"
          name="oldPassword"
          class="form-control my-2"
          placeholder="Current password"
          required
          value="<%= typeof oldPassword !== 'undefined' ? oldPassword : '' %>"
        />
        <% if (errors && errors.oldPassword) { %>
        <span class="text-danger"><%= errors.oldPassword %></span>
        <% } %>

        <input
          type="password"
          name="Password"
          class="form-control my-2"
          placeholder="New password"
          required
          value="<%= typeof Password !== 'undefined' ? Password : '' %>"
        />
        <% if (errors && errors.Password) { %>
        <span class="text-danger"><%= errors.Password %></span>
        <% } %>

        <input
          type="password"
          name="confirmPassword"
          class="form-control my-2"
          placeholder="Confirm password"
          required
          value="<%= typeof confirmPassword !== 'undefined' ? confirmPassword : '' %>"
        />
        <% if (errors && errors.confirmPassword) { %>
        <span class="text-danger"><%= errors.confirmPassword %></span>
        <% } %>

        <button type="submit" class="btn btn-success">submit</button>
      </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
