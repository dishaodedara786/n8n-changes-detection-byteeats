<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>ByteEats | Add Food Item</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
      rel="stylesheet"
    />

    <style>
    body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }
      /* Center the ByteEats logo */
.sidebar .logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 1.5rem;
}

.sidebar .logo a {
  font-size: 1.8rem; /* Adjust size if needed */
  font-weight: bold;
  color: #333; /* Adjust text color */
  text-decoration: none;
}

.sidebar .logo a:hover {
  color: #007bff; /* Change color on hover if desired */
}


    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('../partials/header') %>

      <!-- Flash Messages -->
  

      <h2 class="mb-4 text-center">Add New Food Item</h2>

      <div class="form-container">
        <form
          action="/admin/create/food-item"
          method="POST"
          enctype="multipart/form-data"
          id="form"
        >
          <div class="mb-3">
            <label for="name" class="form-label">Food Name</label>
            <input
              type="text"
              name="name"
              id="name"
              class="form-control <%= errors && errors.name ? 'is-invalid' : '' %>"
              value="<%= typeof name !== 'undefined' ? name : '' %>"
              
            />
            <% if (errors && errors.name) { %>
            <div class="text-danger"><%= errors.name %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label for="category_id" class="form-label">Category</label>
            <select
              name="category_id"
              id="category_id"
              class="form-control <%= errors && errors.category_id ? 'is-invalid' : '' %>"
            
            >
              <option value="">Select a Category</option>
              <% categories.forEach(category => { %>
              <option value="<%= category.id %>" <%= category_id == category.id ? 'selected' : '' %>>
                <%= category.name %>
              </option>
              <% }) %>
            </select>
            <% if (errors && errors.category_id) { %>
            <div class="text-danger"><%= errors.category_id %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label for="price" class="form-label">Price ($)</label>
            <input
              type="number"
              name="price"
              id="price"
              step="0.01"
              min="0"
              class="form-control <%= errors && errors.price ? 'is-invalid' : '' %>"
              value="<%= typeof price !== 'undefined' ? price : '' %>"
              
            />
            <% if (errors && errors.price) { %>
            <div class="text-danger"><%= errors.price %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label for="stock" class="form-label">Stock Quantity</label>
            <input
              type="number"
              name="stock"
              id="stock"
              min="0"
              class="form-control <%= errors && errors.stock ? 'is-invalid' : '' %>"
              value="<%= typeof stock !== 'undefined' ? stock : '' %>"
              
            />
            <% if (errors && errors.stock) { %>
            <div class="text-danger"><%= errors.stock %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label for="image" class="form-label">Food Image</label>
            <input
              type="file"
              name="image"
              id="image"
              class="form-control"
              accept="image/*"
            />
          </div>

          <button type="submit" class="btn btn-primary btn-register mt-3">
            Add Food Item
          </button>
        </form>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
