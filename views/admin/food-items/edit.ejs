<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Food Item</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
     <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

  <style>
   body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }
      /* Center the ByteEats logo */
.sidebar .logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 1.5rem;
}

.sidebar .logo a {
  font-size: 1.8rem; /* Adjust size if needed */
  font-weight: bold;
  color: #333; /* Adjust text color */
  text-decoration: none;
}

.sidebar .logo a:hover {
  color: #007bff; /* Change color on hover if desired */
}

  </style>
</head>
<body>
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Header -->
    <%- include('../partials/header') %>

    <h2 class="text-center mb-4">Edit Food Item</h2>
    <div class="form-container">
      <form
        action="/admin/edit/food-item/<%= fooditem.id %>"
        method="POST"
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="name" class="form-label">Name</label>
          <input
            type="text"
            name="name"
            class="form-control"
            id="name"
            value="<%= fooditem.name %>"
            required
          />
        </div>
        <% if (errors && errors.name) { %>
  <div class="text-danger"><%= errors.name %></div>
<% } %>


        <div class="mb-3">
          <label for="category_id" class="form-label">Category</label>
          <select name="category_id" class="form-control" required>
            <% categories.forEach(category => { %>
              <option value="<%= category.id %>" <%= fooditem.category_id === category.id ? 'selected' : '' %>>
                <%= category.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <% if (errors && errors.category_id) { %>
 <div class="text-danger"><%= errors.category_id %></div>
<% } %>

        <div class="mb-3">
          <label for="price" class="form-label">Price ($)</label>
          <input
            type="number"
            name="price"
            id="price"
            step="0.01"
            min="0"
            class="form-control"
            value="<%= fooditem.price %>"
            required
          />
        </div>
        <% if (errors && errors.price) { %>
  <div class="text-danger"><%= errors.price %></div>
<% } %>


        <div class="mb-3">
          <label for="stock" class="form-label">Stock</label>
          <input
            type="number"
            name="stock"
            id="stock"
            min="0"
            class="form-control"
            value="<%= fooditem.stock %>"
            required
          />
        </div>
<% if (errors && errors.stock) { %>
  <div class="text-danger"><%= errors.stock%></div>
<% } %>

        <div class="mb-3">
          <label for="image" class="form-label">Change Image</label>
          <input
            type="file"
            name="image"
            class="form-control"
            accept="image/*"
          />
          <% if (fooditem.image) { %>
            <div class="mt-2">
              <img
                src="/uploads/<%= fooditem.image %>"
                alt="Food Image"
                width="80"
                style="border-radius: 5px;"
              />
            </div>
          <% } %>
        </div>

        <div class="btn-group">
          <button type="submit" class="btn btn-success">Update</button>
          <a href="/admin/food-items" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
