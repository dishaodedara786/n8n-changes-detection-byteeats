<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>View Food Item</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
 <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

  <style>
    body {
      display: flex;
      min-height: 100vh;
      margin: 0;
    }
    .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }
      /* Center the ByteEats logo */
.sidebar .logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 1.5rem;
}

.sidebar .logo a {
  font-size: 1.8rem; /* Adjust size if needed */
  font-weight: bold;
  color: #333; /* Adjust text color */
  text-decoration: none;
}

.sidebar .logo a:hover {
  color: #007bff; /* Change color on hover if desired */
}
    .food-info {
      background: #fff;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 0 8px rgba(0,0,0,0.1);
      max-width: 500px;
      margin: 0 auto;
      text-align: center;
    }
    .food-image {
      width: 120px;
      height: 120px;
      object-fit: cover;
      border-radius: 10px;
      border: 3px solid #007bff;
      margin-bottom: 20px;
    }
    .btn-group {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 20px;
    }
    h4 {
      margin-bottom: 10px;
    }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Header -->
    <%- include('../partials/header') %>

    <h2 class="text-center mb-4">Food Item Details</h2>

    <div class="food-info">
      <img
        src="/uploads/<%= fooditem.image || 'default-food.png' %>"
        alt="Food Image"
        class="food-image"
      />

      <h4><%= fooditem.name %></h4>
      <p><strong>Category:</strong> <%= categoryMap[fooditem.category_id] || 'N/A' %></p>
      <p><strong>Price:</strong> $<%= fooditem.price %></p>
      <p><strong>Stock:</strong> <%= fooditem.stock %></p>

      <div class="btn-group">
        <a href="/admin/edit/food-item/<%= fooditem.id %>" class="btn btn-primary">Edit</a>
        <a href="/admin/food-items" class="btn btn-secondary">Back</a>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
