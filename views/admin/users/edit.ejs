<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>ByteEats | Edit User</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }

      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }

      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }

      .sidebar a:hover {
        background-color: #495057;
      }

      .main-content {
        flex: 1;
        padding: 30px;
        background-color: #f1f3f5;
      }

      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }

      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }

      .avatar-container {
        position: relative;
        width: 120px;
        margin: 0 auto 20px;
      }

      .profile-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid #ced4da;
      }

      .change-avatar-label {
        position: absolute;
        bottom: 0;
        right: 0;
        background-color: #28a745;
        color: white;
        border-radius: 50%;
        padding: 5px 7px;
        font-size: 16px;
        cursor: pointer;
        border: 2px solid white;
        transition: background-color 0.3s ease;
      }

      .change-avatar-label:hover {
        background-color: #218838;
      }

      #avatar {
        display: none;
      }

      .form-container {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);
      }

      .text-danger {
        font-size: 0.875em;
      }
    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('../partials/header') %>


      <h2 class="mb-4 text-center">Edit User</h2>
      <div class="row justify-content-center">
        <div class="col-md-8 form-container">
          <!-- Avatar -->
          <div class="text-center avatar-container">
            <img
              src="<%= user.avatar ? ('/uploads/' + user.avatar) : '/default-avatar.png' %>"
              alt="Avatar"
              class="profile-avatar"
              id="avatarPreview"
            />
            <label for="avatar" class="change-avatar-label" title="Change Avatar">✎</label>
          </div>

          <form
            action="/admin/edit/user/<%= user.id %>"
            method="POST"
            enctype="multipart/form-data"
          >
            <!-- Hidden File Input -->
            <input
              type="file"
              class="form-control"
              name="avatar"
              id="avatar"
              accept="image/*"
              onchange="previewAvatar(this)"
            />
            <% if (errors && errors.avatar) { %>
              <div class="text-danger text-center mb-2"><%= errors.avatar %></div>
            <% } %>

            <!-- Name -->
            <div class="mb-3">
              <label for="name" class="form-label">Name</label>
              <input
                type="text"
                class="form-control"
                name="name"
                id="name"
                value="<%= user.name %>"
                required
              />
              <% if (errors && errors.name) { %>
                <div class="text-danger"><%= errors.name %></div>
              <% } %>
            </div>

            <!-- Email -->
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                class="form-control"
                name="email"
                id="email"
                value="<%= user.email %>"
                required
              />
              <% if (errors && errors.email) { %>
                <div class="text-danger"><%= errors.email %></div>
              <% } %>
            </div>

            <!-- Phone -->
            <div class="mb-3">
              <label for="phone" class="form-label">Phone</label>
              <input
                type="text"
                class="form-control"
                name="phone"
                id="phone"
                value="<%= user.phone %>"
                required
              />
              <% if (errors && errors.phone) { %>
                <div class="text-danger"><%= errors.phone %></div>
              <% } %>
            </div>

            <!-- Role -->
            <div class="mb-4">
              <label for="role" class="form-label">Role</label>
              <select class="form-select" name="role" id="role" required>
                <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
              </select>
              <% if (errors && errors.role) { %>
                <div class="text-danger"><%= errors.role %></div>
              <% } %>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between">
              <button type="submit" class="btn btn-success">Update</button>
              <a href="/admin/users" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      function previewAvatar(input) {
        const file = input.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function (e) {
            document.getElementById("avatarPreview").src = e.target.result;
          };
          reader.readAsDataURL(file);
        }
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
