<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ByteEats | Admin Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
     <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">


    <style>
      body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }
      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }
      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main-content {
        flex: 1;
        padding: 30px;
      }
      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }
      .navbar {
        background-color: #d1d5db; /* slightly darker than #dee2e6 */
        padding: 12px 20px;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <!-- Sidebar -->

    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('../partials/header') %>

    <% if (success_msg) { %>

    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success_msg %>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
    <% } %> <% if (error_msg) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= error_msg %>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
    <% } %>

    <!-- Users Table -->
    <!-- Add User Button -->
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="mb-0">Users</h2>
      <a href="/admin/create/user" class="btn btn-success">
        <i class="bi bi-person-plus-fill"></i> Add User
      </a>
    </div>

    <!-- Users Table -->
    <div class="table-responsive">
      <table class="table table-bordered table-hover mt-3">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Registered At</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users && users.length > 0) { %>
            <% users.forEach(function(user, index) { %>
          
          <tr>
            <td><%= index + 1 %></td>
            <td><%= user.name || "N/A" %></td>
            <td><%= user.email || "N/A" %></td>
            <td><%= user.phone || "N/A" %></td>
            <td><%= new Date(user.created_at).toLocaleString() %></td>
            <td>
              <a
                href="/admin/view/user/<%= user.id %>"
                class="btn btn-sm btn-info me-1"
                title="View"
              >
                <i class="bi bi-eye-fill"></i>
              </a>
              <a
                href="/admin/edit/user/<%= user.id %>"
                class="btn btn-sm btn-primary me-1"
                title="Edit"
              >
                <i class="bi bi-pencil-fill"></i>
              </a>
              <form
                action="/admin/delete/user/<%= user.id %>?_method=DELETE"
                method="POST"
                style="display: inline"
              >
                <button
                  type="submit"
                  class="btn btn-sm btn-danger"
                  title="Delete"
                  onclick="return confirm('Are you sure you want to delete this user?')"
                >
                  <i class="bi bi-trash-fill"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }); %> <% } else { %>
          <tr>
            <td colspan="6" class="text-center">No users found.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
