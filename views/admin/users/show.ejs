<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>ByteEats | View User</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        display: flex;
        min-height: 100vh;
        margin: 0;
      }

      .sidebar {
        width: 220px;
        background-color: #343a40;
        padding-top: 20px;
        color: white;
        min-height: 100vh;
      }

      .sidebar a {
        display: block;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        font-weight: 500;
      }

      .sidebar a:hover {
        background-color: #495057;
      }

      .main-content {
        flex: 1;
        padding: 30px;
        background-color: #f1f3f5;
      }

      .navbar {
        background-color: #d1d5db;
        padding: 12px 20px;
        border-radius: 8px;
      }

      .navbar-brand {
        font-weight: bold;
        color: red !important;
      }

      .user-info {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        margin: 0 auto;
      }

      .profile-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 3px solid #007bff;
        margin-bottom: 20px;
      }

      .btn-group {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 20px;
      }

      h4 {
        margin-bottom: 10px;
      }
    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header/Navbar -->
      <%- include('../partials/header') %>

      <h2 class="text-center mb-4">User Details</h2>
      <div class="user-info text-center">
        <img
          src="<%= user.avatar ? ('/uploads/' + user.avatar) : '/default-avatar.png' %>"
          alt="Avatar"
          class="profile-avatar"
        />

        <h4><%= user.name %></h4>
        <p><strong>Email:</strong> <%= user.email %></p>
        <p><strong>Phone:</strong> <%= user.phone %></p>
        <p><strong>Role:</strong> <%= user.role %></p>

        <div class="btn-group">
          <a href="/admin/edit/user/<%= user.id %>" class="btn btn-primary">Edit</a>
          <a href="/admin/users" class="btn btn-secondary">Back</a>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
