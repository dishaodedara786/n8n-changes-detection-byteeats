<!DOCTYPE html>
<html lang="en">
	<head>
		<title>ByteEats | Verify OTP</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				font-family: sans-serif;
			}

			body {
				display: flex;
				justify-content: center;
				align-items: center;
				height: 100vh;
				background-color: #f4f4f4;
			}

			.container {
				background: white;
				padding: 20px;
				border-radius: 10px;
				box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
				width: 350px;
				text-align: center;
			}

			h2 {
				margin-bottom: 15px;
				color: #333;
			}

			input {
				width: 100%;
				margin-bottom: 10px;
				padding: 8px;
				border: 1px solid #ccc;
				border-radius: 5px;
			}

			button {
				width: 100%;
				padding: 10px;
				background: #28a745;
				color: white;
				border: none;
				border-radius: 5px;
				cursor: pointer;
				font-size: 16px;
			}

			button:hover {
				background: #218838;
			}

			.otp-timer {
				margin-top: 15px;
				font-size: 14px;
				color: #d9534f;
				font-weight: bold;
			}

			#resend {
				display: none;
				margin-top: 10px;
				padding: 8px;
				background: #007bff;
				color: white;
				border: none;
				border-radius: 5px;
				cursor: pointer;
				font-size: 14px;
			}

			#resend:hover {
				background: #0056b3;
			}
		</style>
	</head>

	<body>
		<div class="container">
			<h2>Enter OTP</h2>

			<% if (success_msg) { %>
				<div class="alert alert-success alert-dismissible fade show" role="alert">
					<%= success_msg %>
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				</div>
			<% } %>

			<% if (error_msg) { %>
				<div class="alert alert-danger alert-dismissible fade show" role="alert">
					<%= error_msg %>
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				</div>
			<% } %>

			<form action="/verifylogin" method="POST">
				<input type="text" name="otp" placeholder="Enter OTP" required />
				<button type="submit">Verify OTP</button>
			</form>

			<p class="otp-timer" id="countdown"></p>

			<form id="resendOtpForm" action="/send-otp" method="POST">
				<input type="hidden" name="email" value="<%= email || '' %>" />
				<button type="submit" id="resend">Resend OTP</button>
			</form>
		</div>

		<script>
			const countdownElem = document.getElementById('countdown');
			const resendBtn = document.getElementById('resend');

			const EXPIRY_DURATION = 2 * 60; // 2 minutes in seconds
			let remainingTime = EXPIRY_DURATION;

			function updateCountdown() {
				const minutes = Math.floor(remainingTime / 60);
				const seconds = remainingTime % 60;
				countdownElem.textContent = `OTP expires in: ${minutes}:${seconds < 10 ? '0' : ''}${seconds} minutes`;

				if (remainingTime <= 0) {
					clearInterval(timer);
					countdownElem.textContent = "Expired";
					resendBtn.style.display = "block";
				} else {
					remainingTime--;
				}
			}

			// Start the countdown immediately when the page loads
			const timer = setInterval(updateCountdown, 1000);

			// Check if the OTP is expired based on error message
			<% if (error_msg && error_msg.includes('expired')) { %>
					countdownElem.textContent = "OTP expired.";
					resendBtn.style.display = "block";
					clearInterval(timer); // Stop countdown on error message
			<% } %>

			// Show the "Resend OTP" button if expired
			resendBtn.style.display = "none";
			setTimeout(() => {
				if (remainingTime <= 0) {
					resendBtn.style.display = "block";
				}
			}, EXPIRY_DURATION * 1000);
		</script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>