<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>ByteEats | Cart</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<style>
			.cart-item {
				border: 1px solid #ccc;
				border-radius: 10px;
				padding: 15px;
				background-color: #f9f9f9;
				transition: 0.3s;
			}

			.cart-item:hover {
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
			}

			.qty-controls {
				display: flex;
				align-items: center;
				gap: 10px;
			}

			.qty-btn {
				width: 32px;
				height: 32px;
				font-size: 1.2rem;
				text-align: center;
				line-height: 1;
			}
		</style>
	</head>

	<body>
		<%- include('partials/header') %>

		<% if (success_msg) { %>
			<div class="alert alert-success alert-dismissible fade show" role="alert">
				<%= success_msg %>
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		<% } %>

		<% if (error_msg) { %>
			<div class="alert alert-danger alert-dismissible fade show" role="alert">
				<%= error_msg %>
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		<% } %>

		<div class="container mt-5">
			<h4 class="mb-4">Your Cart</h4>

			<% if (cartItems.length> 0) { %>
				<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
					<% cartItems.forEach(item=> { %>
						<div class="col">
							<div class="cart-item text-center">
								<a href="/cart/<%= item.food.id %>">
									<img src="/uploads/<%= item.food.image %>"
										alt="<%= item.food.name %>" class="img-fluid rounded mb-2"
										style="width: 80px; height: 80px; object-fit: cover" />
								</a>
								<h5>
									<a href="/cart/<%= item.food.id %>"
										class="text-decoration-none text-dark">
										<%= item.food.name %>
									</a>
								</h5>

								<p class="text-muted mb-1">$<%= item.food.price %></p>
								<small>
									<%= item.food.category?.name || 'Uncategorized' %>
								</small>

								<div
									class="d-flex justify-content-center align-items-center gap-2 mt-2">
									<form action="/cart/update/<%= item.food.id %>" method="POST">
										<input type="hidden" name="action" value="decrease" />
										<button class="btn btn-sm btn-outline-secondary qty-btn">−</button>
									</form>
									<span class="fw-bold">
										<%= item.quantity %>
									</span>
									<form action="/cart/update/<%= item.food.id %>" method="POST">
										<input type="hidden" name="action" value="increase" />
										<button
											class="btn btn-sm btn-outline-secondary qty-btn">+</button>
									</form>
								</div>

								<form action="/cart/remove/<%= item.food.id %>" method="POST"
									class="mt-2">
									<button class="btn btn-sm btn-danger">Remove</button>
								</form>
							</div>
						</div>
					<% }) %>
				</div>

				<div class="mt-4 text-end">
					<h5>Total: $<%= totalAmount %>
					</h5>
					<a href="/checkout" class="btn btn-success mt-2">Proceed to Checkout</a>
				</div>
			<% } else { %>
				<div class="alert alert-info">Your cart is empty.</div>
			<% } %>
		</div>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>