<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>ByteEats | Dashboard</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<style>
			.logo {
				font-size: 2rem;
				font-weight: bold;
				color: #ff5722;
			}

			.logo:hover {
				color: #0056b3 !important;
			}

			.food-item {
				border: 1px solid #ccc;
				border-radius: 10px;
				padding: 15px;
				text-align: center;
				background-color: #f9f9f9;
				transition: 0.3s;
				min-height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}

			.food-item:hover {
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
			}

			.dropdown-menu a {
				cursor: pointer;
			}
		</style>
	</head>

	<body>
		<%- include('partials/header') %>

		<div class="container mt-5">

			<% if (success_msg) { %>
				<div class="alert alert-success alert-dismissible fade show" role="alert">
					<%= success_msg %>
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				</div>
			<% } %>

			<% if (error_msg) { %>
				<div class="alert alert-danger alert-dismissible fade show" role="alert">
					<%= error_msg %>
					<button type="button" class="btn-close" data-bs-dismiss="alert"
							aria-label="Close"></button>
				</div>
			<% } %>

			<div class="container mt-4">
				<% if (user) { %>
					<h4 class="mb-4">Welcome, <%= user.name %>!</h4>
				<% } else { %>
					<h4 class="mb-4">Welcome, Guest!</h4>
				<% } %>

				<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
					<% if (fooditems.length> 0) { %> 
						<% fooditems.forEach((item)=> { %>
							<div class="col d-flex">
								<div class="food-item text-center w-100 d-flex flex-column justify-content-between h-100">
									<div>
										<a href="/cart/<%= item.id %>">
											<img src="/uploads/<%= item.image || 'default-food.png' %>"
												class="img-fluid rounded-circle mb-2"
												alt="<%= item.name %>"
												style="width: 100px; height: 100px; object-fit: cover" />
										</a>
										<h6 class="mt-2">
											<a href="/cart/<%= item.id %>"
												class="text-decoration-none text-dark">
												<%= item.name %>
											</a>
										</h6>
										<p class="text-muted mb-1">$<%= item.price %></p>
										<span class="badge bg-secondary mb-2">
											<%= item.category?.name || 'Uncategorized' %>
										</span>
									</div>
									<div>
										<form action="/cart/add/<%= item.id %>"
											method="POST" class="d-inline me-1">
											<input type="hidden" name="itemId"
												value="<%= item.id %>">
											<button type="submit"
												class="btn btn-sm btn-primary mt-2">Add to
												Cart</button>
										</form>
										<form action="/favourites/add/<%= item.id %>"
											method="POST" class="d-inline">
											<input type="hidden" name="itemId"
												value="<%= item.id %>">
											<button type="submit"
												class="btn btn-sm btn-outline-danger mt-2">Add to Favourites</button>
										</form>
									</div>
								</div>
							</div>
						<% }) %>
					<% } else { %>
						<div class="col">
							<p>No food items available.</p>
						</div>
					<% } %>
				</div>
			</div>
		</div>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>