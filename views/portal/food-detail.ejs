<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>ByteEats | Dashboard</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<style>
			.logo {
				font-size: 2rem;
				font-weight: bold;
				color: #ff5722;
			}
			.logo:hover {
				color: #0056b3 !important;
			}
			.food-item {
				border: 1px solid #ccc;
				border-radius: 10px;
				padding: 15px;
				text-align: center;
				background-color: #f9f9f9;
				transition: 0.3s;
			}
			.food-item:hover {
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
			}
			.dropdown-menu a {
				cursor: pointer;
			}
		</style>
	</head>

	<body>
	
		<%- include('partials/header') %>

		<div class="container mt-5">
			<div class="card mx-auto" style="max-width: 500px;">
				<img
				src="/uploads/<%= food.image %>"
				class="card-img-top"
				alt="<%= food.name %>"
				/>
				<div class="card-body">
					<h5 class="card-title"><%= food.name %></h5>
					<p class="card-text">Price: $<%= food.price %></p>
					<p class="card-text">Category: <%= food.category?.name || 'Uncategorized' %></p>

					<form action="/cart/add/<%= food.id %>" method="POST" class="d-inline">
						<input type="hidden" name="itemId" value="<%= food.id %>">
						<button type="submit" class="btn btn-primary">Add to Cart</button>
					</form>

					<form action="/favourites/add/<%= food.id %>" method="POST" class="d-inline">
						<input type="hidden" name="itemId" value="<%= food.id %>">
						<button type="submit" class="btn btn-outline-danger">Add to Favourites</button>
					</form>
				</div>
			</div>
		</div>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>