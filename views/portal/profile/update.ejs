<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>ByteEats / Update Profile</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<style>
			.logo {
				font-size: 2rem;
				font-weight: bold;
				color: #ff5722;
			}

			.logo:hover {
				color: #0056b3 !important;
			}

			.profile-avatar {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid white;
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
			}

			.avatar-container {
				position: relative;
				display: inline-block;
				margin-bottom: 20px;
			}

			.change-avatar-label {
				position: absolute;
				bottom: 0;
				right: 0;
				background-color: #0d6efd;
				color: white;
				padding: 6px 7px;
				font-size: 14px;
				border-radius: 50%;
				cursor: pointer;
				box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);
			}

			.change-avatar-label:hover {
				background-color: #0056b3;
			}
		</style>
	</head>

	<body>
		<%- include('../partials/header') %>

		<div class="container mt-5">
			<div class="row justify-content-center">
				<div class="col-md-6 text-center">
					<div class="avatar-container">
						<img src="<%= user.avatar ? ('/uploads/' + user.avatar) : '/default-avatar.png' %>" alt="Avatar"
							class="profile-avatar" id="avatarPreview" />
						<label for="avatar" class="change-avatar-label" title="Change Avatar">✎</label>
					</div>

					<form action="/update-profile" method="POST" enctype="multipart/form-data" class="text-start">
						<input type="file" id="avatar" name="avatar" class="d-none" accept="image/*"
							onchange="previewAvatar(event)" />

						<div class="form-group mb-3">
							<label for="name">Name</label>
							<input type="text" class="form-control" name="name" id="name" value="<%= user.name %>"
								required />
							<% if (errors && errors.name) { %>
								<span class="text-danger">
									<%= errors.name %>
								</span>
							<% } %>
						</div>
						<div class="form-group mb-3">
							<label for="email">Email</label>
							<input type="email" class="form-control" name="email" id="email" value="<%= user.email %>"
								required />
							<% if (errors && errors.email) { %>
								<span class="text-danger">
									<%= errors.email %>
								</span>
							<% } %>
						</div>
						<div class="form-group mb-3">
							<label for="phone">Phone</label>
							<input type="text" class="form-control" name="phone" id="phone" value="<%= user.phone %>"
								required />
							<% if (errors && errors.phone) { %>
								<span class="text-danger">
									<%= errors.phone %>
								</span>
							<% } %>
						</div>
						<div class="text-end mb-3">
							<a href="/change-password" class="text-primary">Change Password</a>
						</div>
						<button type="submit" class="btn btn-primary w-100">
							Save Changes
						</button>
					</form>
				</div>
			</div>
		</div>
		<script>
			function previewAvatar(event) {
				const reader = new FileReader();
				reader.onload = function () {
					document.getElementById("avatarPreview").src = reader.result;
				};
				reader.readAsDataURL(event.target.files[0]);
			}
		</script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>