<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>ByteEats | Favourites</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<style>
			.fav-item {
				border: 1px solid #ccc;
				border-radius: 10px;
				padding: 15px;
				background-color: #fff0f0;
				transition: 0.3s;
			}
			.fav-item:hover {
				box-shadow: 0 0 10px rgba(255, 0, 0, 0.3);
			}
		</style>
	</head>

	<body>
		<%- include('partials/header') %>

		<% if (success_msg) { %>
			<div class="alert alert-success alert-dismissible fade show" role="alert">
				<%= success_msg %>
				<button
				type="button"
				class="btn-close"
				data-bs-dismiss="alert"
				aria-label="Close"
				></button>
			</div>
		<% } %>

		<% if (error_msg) { %>
			<div class="alert alert-danger alert-dismissible fade show" role="alert">
				<%= error_msg %>
				<button
				type="button"
				class="btn-close"
				data-bs-dismiss="alert"
				aria-label="Close"
				></button>
			</div>
		<% } %>

		<div class="container mt-5">
			<h4 class="mb-4">Your Favourites</h4>

			<% if (favourites.length > 0) { %>
				<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
					<% favourites.forEach(item => { %>
						<div class="col">
							<div class="fav-item text-center">
								<a href="/cart/<%= item.id %>">
									<img
										src="/uploads/<%= item.image || 'default-food.png' %>"
										alt="<%= item.name %>"
										class="img-fluid rounded mb-2"
										style="width: 100px; height: 100px; object-fit: cover"
									/>
								</a>
								<h6>
									<a href="/cart/<%= item.id %>" class="text-decoration-none text-dark">
										<%= item.name %>
									</a>
								</h6>
								<p class="text-muted mb-1">$<%= item.price %></p>
								<small><%= item.category?.name || 'Uncategorized' %></small>

								<form action="/favourites/remove/<%= item.id %>" method="POST" class="mt-2">
									<button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
								</form>
							</div>
						</div>
					<% }) %>
				</div>
			<% } else { %>
				<div class="alert alert-info">You have no favourite items yet.</div>
			<% } %>
		</div>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>